Algoritmo REGISTRODEESTUDIANTE
DEFINIR NOMBRE, CARRERA COMO CARACTER
DEFINIR EDAD, SEMESTRE, TELEFONO COMO ENTERO
ESCRIBIR " INGRESE NOMBRE DEL ESTUDIANTE:"
LEER NOMBRE
ESCRIBIR " INGRESE SU EDAD:"
LEER EDAD
ESCRIBIR " INGRESE SU CARRERA:"
LEER CARRERA
ESCRIBIR " INGRESE SU SEMESTRE:"
LEER SEMESTRE
ESCRIBIR " INGRESE SU TELEFONO:"
LEER TELEFONO
ESCRIBIR "DATOS DE ESTUDIANTE:"
ESCRIBIR "NOMBRE:" , NOMBRE
ESCRIBIR "EDAD: ", EDAD
ESCRIBIR "CARRERA:", CARRERA
ESCRIBIR "SEMESTRE:", SEMESTRE
ESCRIBIR "TELEFONO:", TELEFONO
FinAlgoritmo
#include <stdio.h>

int main() {

char nombre[50];
int edad;
char carrera[50];
int semestre;
int telefono;

printf("Ingrese nombre del estudiante: ");
scanf("%s", nombre);

printf("Ingrese edad: ");
scanf("%d", &edad);

printf("Ingrese carrera: ");
scanf("%s", carrera);

printf("Ingrese semestre: ");
scanf("%d", &semestre);

printf("Ingrese telefono: ");
scanf("%d" , &telefono);

printf("\nDatos del estudiante\n");
printf("Nombre: %s\n", nombre);
printf("Edad: %d\n", edad);
printf("Carrera: %s\n", carrera);
printf("Semestre: %d\n", semestre);
printf("Telefono: %d\n", telefono);

return 0;
}
