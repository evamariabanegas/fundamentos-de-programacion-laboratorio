#include <stdio.h>

int main() {

float base;
float altura;
float area;

printf("Ingrese base: ");
scanf("%f", &base);

printf("Ingrese altura: ");
scanf("%f", &altura);

area = (base * altura) / 2;

printf("El area del triangulo es: %.2f\n", area);
return 0;
}
